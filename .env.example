#
# VoiceQA configuration
#
# Copy to `.env` and adjust as needed.
#

# Whisper model name (OpenAI Whisper checkpoints)
WHISPER_MODEL=small

# Ollama models used for the LLM-based checks.
# If Ollama is not running / models are missing, VoiceQA will fall back gracefully.
FAITHFULNESS_MODEL=llama3.2
REPORT_MODEL=phi3.5

